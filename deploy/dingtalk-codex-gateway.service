[Unit]
Description=DingTalk Codex Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/dingtalk-codex-gateway
EnvironmentFile=/etc/dingtalk-codex-gateway.env
ExecStart=/usr/bin/python3 -m src.server --env-file /etc/dingtalk-codex-gateway.env
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
