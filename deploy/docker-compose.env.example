# Copy to deploy/docker-compose.env before running docker compose.
# Keep this file private; it contains the HTTP bearer token.
DINGTALK_GATEWAY_API_TOKEN=replace-with-a-long-random-token
DINGTALK_GATEWAY_AGENT_TOKEN=replace-with-a-different-long-random-agent-token
DINGTALK_GATEWAY_ENV=production
DINGTALK_GATEWAY_DEFAULT_WORKSPACE=default
DINGTALK_GATEWAY_JOB_DB_PATH=/app/data/jobs.sqlite3
DINGTALK_GATEWAY_BIND_IP=127.0.0.1
DINGTALK_GATEWAY_PUBLISHED_PORT=8787

# Public HTTPS. Required when using compose.https.yaml.
DINGTALK_GATEWAY_DOMAIN=gateway.example.com
CADDY_ACME_EMAIL=ops@example.com

# Host paths mounted into the container.
WORKSPACE_HOST_PATH=./workspace
CODEX_CONFIG_DIR=/root/.codex
META_ADS_MCP_CONFIG_DIR=/root/.config/meta-ads-mcp

# Optional. If absent, the container also reads /root/.config/meta-ads-mcp/env.
# META_ACCESS_TOKEN=replace-with-meta-token

# Optional DingTalk callback / outgoing robot settings.
DINGTALK_CALLBACK_TOKEN=replace-with-callback-token
# DINGTALK_OUTGOING_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=replace
# DINGTALK_OUTGOING_SECRET=replace-with-robot-secret
